{
  "functions": {
    "api/*.js": {
      "includeFiles": "results/**"
    }
  },
  "rewrites": [
    { "source": "/api/trades/stats", "destination": "/api/trades" },
    { "source": "/api/trades/export", "destination": "/api/trades" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
